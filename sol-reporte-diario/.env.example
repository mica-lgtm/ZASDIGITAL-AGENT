# Copiar a .env (gitignored) y completar con datos reales.
# Tienda Nube NO tiene credenciales acá: canales/tienda_nube.py reusa
# dante-desarrollo-tn/.env (DANTE_<MARCA>_STORE_ID/_TOKEN/_URL) de solo lectura.

# --- Google Sheets (planilla maestra de clientes) ---
SOL_SHEETS_SPREADSHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SOL_SHEETS_SERVICE_ACCOUNT_FILE=secrets/sheets-service-account.json
SOL_SHEETS_HOJA_ROSTER=Roster
SOL_SHEETS_HOJA_DATOS=Datos Diarios

# --- Meta Ads (cuenta compartida a nivel Business Manager) ---
SOL_META_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SOL_META_API_VERSION=v19.0

# --- Meta Ads por marca: ID de cuenta publicitaria (sin "act_") ---
SOL_PILOTO_META_AD_ACCOUNT_ID=000000000000000

# --- Google Ads (cuenta MCC compartida) ---
SOL_GOOGLE_ADS_DEVELOPER_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxx
SOL_GOOGLE_ADS_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
SOL_GOOGLE_ADS_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx
SOL_GOOGLE_ADS_REFRESH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxx
SOL_GOOGLE_ADS_LOGIN_CUSTOMER_ID=0000000000

# --- Google Ads por marca: ID de cuenta de cliente (con o sin guiones) ---
SOL_PILOTO_GOOGLE_ADS_CUSTOMER_ID=000-000-0000

# --- WhatsApp Cloud API (Fase 4 — requiere setup previo, ver README) ---
SOL_WHATSAPP_API_VERSION=v19.0
SOL_WHATSAPP_PHONE_NUMBER_ID=000000000000000
SOL_WHATSAPP_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SOL_WHATSAPP_TEMPLATE_NAME=reporte_diario
SOL_WHATSAPP_RECIPIENT_MICA=+549xxxxxxxxxx
