# Copiar a .env (gitignored) y completar con datos reales.
# Ada NO tiene credenciales de Meta/Tienda Nube acá: roster_ada.py reusa
# sol-reporte-diario/roster.py + sheets.py (de solo lectura) para saber qué
# marca tiene el canal google_ads activo. La planilla sigue siendo la única
# fuente de verdad para ese toggle.

# --- Google Sheets (misma planilla maestra que usa Sol) ---
ADA_SHEETS_SPREADSHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADA_SHEETS_SERVICE_ACCOUNT_FILE=secrets/sheets-service-account.json
ADA_SHEETS_HOJA_ROSTER=Roster

# --- Google Ads (misma MCC y developer token que Sol; client OAuth PROPIO de
# Ada -- no reusar SOL_GOOGLE_ADS_REFRESH_TOKEN. Ver CLAUDE.md, sección
# "Conexión a Google Ads", para la razón de seguridad de esta separación) ---
ADA_GOOGLE_ADS_DEVELOPER_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxx
ADA_GOOGLE_ADS_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
ADA_GOOGLE_ADS_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx
ADA_GOOGLE_ADS_REFRESH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxx
ADA_GOOGLE_ADS_LOGIN_CUSTOMER_ID=0000000000

# --- Google Ads por marca: mismo customer ID que SOL_<MARCA>_GOOGLE_ADS_CUSTOMER_ID ---
ADA_PILOTO_GOOGLE_ADS_CUSTOMER_ID=000-000-0000

# --- WhatsApp Cloud API (mismo número/token que Sol; plantilla nueva) ---
ADA_WHATSAPP_API_VERSION=v19.0
ADA_WHATSAPP_PHONE_NUMBER_ID=000000000000000
ADA_WHATSAPP_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADA_WHATSAPP_TEMPLATE_NAME=ada_resumen_ejecutivo
ADA_WHATSAPP_RECIPIENT_MICA=+549xxxxxxxxxx
